        $meseOdierno = $date->format('m');  
        
        if ( (12 - $meseOdierno) == 0) {$mesiMancanti = 1;}
        else { $mesiMancanti = 12 - $meseOdierno; }

        $valore_A = 800000;
        $valore_C = ( ( $valore_BP + $valore_EP ) / 6 ) * $mesiMancanti ;   // Valore ipotetico delle ammissioni da Capitale + Fondo da oggi a fine anno

