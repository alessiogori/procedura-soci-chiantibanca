$select_MAX_nazioni_al =   "
                        SELECT
                            MAX(SOCI_CERTIFICATI.NAZIONI_AL) as MAXAZIONIAL
                        FROM
                            SOCI_CERTIFICATI  
                        WHERE
                            SOCI_CERTIFICATI.DATA_ACQUISTO <=  '".$_GET['datain']."' 
                        ";
      
