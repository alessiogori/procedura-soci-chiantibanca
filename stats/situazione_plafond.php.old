$select_movim_entrataD =   "
                        SELECT A.IDSOCIO, B.NAG, C.INTESTAZIONE_A, C.INTESTAZIONE_B, A.DATA_MOVIMENTO, A.CTIPOMOV AS TIPO, A.IMPORTO, A.ISOVRAPPREZZO 
