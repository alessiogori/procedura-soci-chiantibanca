// ----------------------------------------------------------------------------------------------------------
// 01 - NUOVE AMMISSIONI + ULTERIORI QUOTE (da Fondo) - DA INIZIO ANNO - DETTAGLIO
// Eq. Soci Stampe Generali > Situazione Fondo Riacquisto Azioni > dal 01.01.2022 flag "solo in Uscita"
// ----------------------------------------------------------------------------------------------------------
$select_movim_fondo_us_D =   "
                        SELECT 
                        R.IDSOCIO,
                        R.IDCERTIFICATO,
                        R.NAZIONI,
                        R.TIPO_OPERAZIONE,
                        A.NAG, 
                        N.INTESTAZIONE_A,
                        N.INTESTAZIONE_B, 
                        V.IVAL_AZIONI,
                        (R.NAZIONI * V.IVAL_AZIONI) AS IMPORTO,
                        CASE R.TIPO_OPERAZIONE WHEN 'E' THEN 'In entrata' ELSE 'In uscita' END AS TIPO 
                        FROM 
                        SOCI_RIACQUISTO_AZIONI R, SOCI_ANAGRAFICA A, ANAG_NAG N, SOCI_VALORE_AZIONI V
                        WHERE R.IDSOCIO = A.IDSOCIO 
                        AND A.NAG = N.NAG
                        AND R.IDAZIONE = V.IDAZIONE 
                        AND R.DATA_MOVIMENTO >= '".$_GET['datain']."' 
                        AND R.TIPO_OPERAZIONE = 'U'
                    
                        ";

// ----------------------------------------------------------------------------------------------------------
// 01 - NUOVE AMMISSIONI + ULTERIORI QUOTE (da Fondo) - DA INIZIO ANNO - RIEPILOGO PER TIPOLOGIA
// ----------------------------------------------------------------------------------------------------------
$select_movim_fondo_us_R =   "
                        SELECT count(*) as qta,
                        CASE 
                            R.TIPO_OPERAZIONE WHEN 'E' THEN 'In entrata' ELSE 'In uscita'
                        END AS TIPO ,
                            SUM(R.NAZIONI * V.IVAL_AZIONI) AS SUM_IMPORTO  
                        FROM 
                        SOCI_RIACQUISTO_AZIONI R, SOCI_VALORE_AZIONI V
                        WHERE R.IDAZIONE = V.IDAZIONE 
                        AND R.DATA_MOVIMENTO >= '".$_GET['datain']."' 
                        AND R.TIPO_OPERAZIONE = 'U'
                        GROUP BY CASE R.TIPO_OPERAZIONE WHEN 'E' THEN 'In entrata' ELSE 'In uscita' END
                        ";

// ----------------------------------------------------------------------------------------------------------
// 01 - NUOVE AMMISSIONI + ULTERIORI QUOTE (da Fondo) - DA INIZIO ANNO - TOTALE GENERALE
// ----------------------------------------------------------------------------------------------------------
$select_movim_fondo_us_T =   "
                        SELECT 
                            count(*) as TOTALE_QTA,
                            SUM(R.NAZIONI * V.IVAL_AZIONI) AS TOTALE_IMPORTO  
                        FROM 
                        SOCI_RIACQUISTO_AZIONI R, SOCI_VALORE_AZIONI V
                        WHERE R.IDAZIONE = V.IDAZIONE 
                        AND R.DATA_MOVIMENTO >= '".$_GET['datain']."' 
                        AND R.TIPO_OPERAZIONE = 'U'
                    ";

$select_movim_fondo_us_TP =   "
                        SELECT 
                            count(*) as TOTALE_QTA,
                            SUM(R.NAZIONI * V.IVAL_AZIONI) AS TOTALE_IMPORTO  
