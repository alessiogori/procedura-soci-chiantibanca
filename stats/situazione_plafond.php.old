// ----------------------------------------------------------------------------------------------------------
// 03 - MOVIMENTI IN USCITA PER PLAFOND - DA INIZIO ANNO - DETTAGLIO
// Eq. Soci Stampe Generali > Stampa Riepilogo Movimenti per Plafond > dal 01.01.2022 flag "solo in Uscita"
// ----------------------------------------------------------------------------------------------------------
$select_movim_uscitaD =   "
                    SELECT 
                    M.IDSOCIO,
                    A.NAG, 
                    N.INTESTAZIONE_A,
                    N.INTESTAZIONE_B, 
                    M.DATA_MOVIMENTO, 
                    M.CTIPOMOV as TIPO,
                    M.IMPORTO,
                    M.ISOVRAPPREZZO 
                    FROM 
                    SOCI_MOVIMENTI M, SOCI_ANAGRAFICA A, ANAG_NAG N
                    WHERE M.IDSOCIO = A.IDSOCIO 
                    AND A.NAG = N.NAG
                    AND M.CTIPOMOV IN ('RE','ES','MO','RL') 
                    AND M.IMPORTO <> 0 
                    AND M.DATA_MOVIMENTO >= '".$_GET['datain']."'
                    ORDER BY DATA_MOVIMENTO
                    ";

// ----------------------------------------------------------------------------------------------------------
// 03 - MOVIMENTI IN USCITA PER PLAFOND - DA INIZIO ANNO - RIEPILOGO PER TIPOLOGIA
// ----------------------------------------------------------------------------------------------------------
$select_movim_uscitaR =   "
                        SELECT count(*) as qta,
                        CASE 
                            WHEN SOCI_MOVIMENTI.CTIPOMOV = 'RE' THEN 'Recesso'
                            WHEN SOCI_MOVIMENTI.CTIPOMOV = 'ES' THEN 'Esclusione'
                            WHEN SOCI_MOVIMENTI.CTIPOMOV = 'RL' THEN 'Morte'
                            WHEN SOCI_MOVIMENTI.CTIPOMOV = 'MO' THEN 'Morte'
                        ELSE ''
                        END AS TIPO ,
                            SUM(SOCI_MOVIMENTI.IMPORTO) AS SUM_IMPORTO ,
                            SUM(SOCI_MOVIMENTI.ISOVRAPPREZZO) AS SUM_SOVRAPPREZZO 
                        FROM
                            SOCI_MOVIMENTI  
                        WHERE
                            SOCI_MOVIMENTI.CTIPOMOV IN ( 'RE','ES','MO','RL' ) 
                        AND
                            SOCI_MOVIMENTI.IMPORTO <> 0 
                        AND
                            SOCI_MOVIMENTI.DATA_MOVIMENTO >=  '".$_GET['datain']."'
                        GROUP BY
                            TIPO
                    ";

// ----------------------------------------------------------------------------------------------------------
// 03 - MOVIMENTI IN USCITA PER PLAFOND - DA INIZIO ANNO - TOTALE GENERALE
// ----------------------------------------------------------------------------------------------------------
$select_movim_uscitaT =   "
                        SELECT 
                            count(*) as TOTALE_QTA,
                            SUM(SOCI_MOVIMENTI.IMPORTO) AS TOTALE_IMPORTO ,
                            SUM(SOCI_MOVIMENTI.ISOVRAPPREZZO) AS TOTALE_SOVRAPPREZZO 
                        FROM
                            SOCI_MOVIMENTI  
                        WHERE
                            SOCI_MOVIMENTI.CTIPOMOV IN ( 'RE','ES','MO','RL' ) 
                        AND
                            SOCI_MOVIMENTI.IMPORTO <> 0 
                        AND
                            SOCI_MOVIMENTI.DATA_MOVIMENTO >=  '".$_GET['datain']."'
                    ";


