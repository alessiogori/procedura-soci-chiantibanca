    // Preparo il file per l'estrazione in CSV
    $contenutofile = '';
    $select_file = "	
	                SELECT 'Liquid.Eredi' as Tipo, filiale, pf_pg, cag, Nominativo, Numero_Azioni, Valore_Nominale, Data_Richiesta, Note_Motivazioni, Anno_Liquidazione,
	                Data_Decesso, Intestazione_a_Eredi, Liquidazione_a_Eredi,
	                '' as Escluso_art_6, '' as Escluso_art_14, '' as Escluso_x_passaggio_a_Sofferenze,
	                '' as Totale_Parziale, '' as Cessione_a_Banca
	                FROM tab_xls_decessi_eredi
	                WHERE Liquidazione_a_eredi = 'S'
	                and Note_AO08 not in ('S2','SM')
	                ".$condizionefiliale."

	                UNION
	               
	                SELECT 'Attesa Eredi' as Tipo, filiale, pf_pg, cag, Nominativo, Numero_Azioni, Valore_Nominale, Data_Richiesta, Note_Motivazioni, Anno_Liquidazione,
	                Data_Decesso, Intestazione_a_Eredi, Liquidazione_a_Eredi,
	                '' as Escluso_art_6, '' as Escluso_art_14, '' as Escluso_x_passaggio_a_Sofferenze,
	                '' as Totale_Parziale, '' as Cessione_a_Banca
	                FROM tab_xls_decessi_eredi
	                WHERE Intestazione_a_eredi <> 'S' 
	                AND Liquidazione_a_eredi <> 'S'
	                and Note_AO08 not in ('S2','SM','')
	                ".$condizionefiliale."

	                UNION
	                
	                SELECT 'Sofferenze' as Tipo, filiale, pf_pg, cag, Nominativo, Numero_Azioni, Valore_Nominale, Data_Richiesta, Note_Motivazioni, Anno_Liquidazione,
	                '' as Data_Decesso, '' as Intestazione_a_Eredi, '' as Liquidazione_a_Eredi,
	                Escluso_art_6, Escluso_art_14, Escluso_x_passaggio_a_Sofferenze,
	                '' as Totale_Parziale, '' as Cessione_a_Banca
	                FROM tab_xls_recessi_esclusioni_sofferenze
	                WHERE Escluso_x_Passaggio_a_Sofferenze = 'S' 
	                and Note_AO08 not in ('S4','SB','SC','')
	                ".$condizionefiliale."

	                UNION
	                
	                SELECT 'Esclusione' as Tipo, filiale, pf_pg, cag, Nominativo, Numero_Azioni, Valore_Nominale, Data_Richiesta, Note_Motivazioni, Anno_Liquidazione,
	                '' as Data_Decesso, '' as Intestazione_a_Eredi, '' as Liquidazione_a_Eredi,
	                Escluso_art_6, Escluso_art_14, Escluso_x_passaggio_a_Sofferenze,
	                '' as Totale_Parziale, '' as Cessione_a_Banca
	                FROM tab_xls_recessi_esclusioni_sofferenze
	                WHERE Escluso_x_Passaggio_a_Sofferenze <> 'S'
	                and Note_AO08 not in ('S4','SA','SB','SC','')
	                ".$condizionefiliale."

	                UNION
	                
	                SELECT 'Cessione Banca' as Tipo, filiale, pf_pg, cag, Nominativo, Numero_Azioni, Valore_Nominale, Data_Richiesta, Note_Motivazioni, '' as Anno_Liquidazione,
	                '' as Data_Decesso, '' as Intestazione_a_Eredi, '' as Liquidazione_a_Eredi,
	                '' as Escluso_art_6, '' as Escluso_art_14, '' as Escluso_x_passaggio_a_Sofferenze,
	                Totale_Parziale, Cessione_a_Banca
	                FROM tab_xls_cessioni
	                WHERE Cessione_a_Banca ='S' 
	                and Note_AO08 not in ('S5','S4','SA','SB','SC','SM','VB') 
	                ".$condizionefiliale."

                    " ;
    //echo $select_file;
    $qry_file = $dbhandle->query($select_file) or exit("Error code ({$dbhandle->errno}): {$dbhandle->error}");    
    $myfile = fopen("../tmp/liquidazioni".$filiale.".csv", "w");
    $contenutofile .= "Tipo;filiale;pf_pg;cag;Nominativo;Numero_Azioni;Valore_Nominale;Data_Richiesta;Note_Motivazioni;Anno_Liquidazione;Data_Decesso; Intestazione_a_Eredi;Liquidazione_a_Eredi;Escluso_art_6;Escluso_art_14;Escluso_x_passaggio_a_Sofferenze;Totale_Parziale;Cessione_a_Banca\n";
    while($cnt_file = mysqli_fetch_array($qry_file)){ 
        $contenutofile .= 
			$cnt_file['Tipo'].";".
			$cnt_file['filiale'].";".
			$cnt_file['pf_pg'].";".
			$cnt_file['cag'].";".
			$cnt_file['Nominativo'].";".
			$cnt_file['Numero_Azioni'].";".	
			$cnt_file['Valore_Nominale'].";".
			$cnt_file['Data_Richiesta'].";".
			$cnt_file['Note_Motivazioni'].";".		
			$cnt_file['Anno_Liquidazione'].";".		
			$cnt_file['Data_Decesso'].";".		
			$cnt_file['Intestazione_a_Eredi'].";".		
			$cnt_file['Liquidazione_a_Eredi'].";".		
			$cnt_file['Escluso_art_6'].";".		
			$cnt_file['Escluso_art_14'].";".		
			$cnt_file['Escluso_x_passaggio_a_Sofferenze'].";".		
			$cnt_file['Totale_Parziale'].";".
			$cnt_file['Cessione_a_Banca']."\n";
    }
    fwrite($myfile, $contenutofile);
    fclose($myfile);


    echo '<center><a class="btn btn-outline-warning" href="../tmp/liquidazioni'.$filiale.'.csv">Scarica il dettaglio completo</a><br><br>';


     // Se la richiesta arriva da una Filiale, NON mostro la tabella dei Totali di Filiale
     if (!isset($_GET['area']))   
     { echo ''; }
     else
     {
?>
<table border="0" align="center" width="70%">
  <tr>     
       <td valign="top" width="50%"><?php echo $tab_dettaglioA1; ?></td>
       <td>&nbsp;&nbsp;&nbsp;</td>
       <td valign="top" width="50%"><?php echo $tab_dettaglioB1; ?></td>
  </tr>
</table>
<br>

<?php
    }
// closing database connection      
$dbhandle->close();       
