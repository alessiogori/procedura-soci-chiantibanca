$viewA = mysqli_query($dbhandle," CREATE VIEW view_liquidazioni as 
                SELECT filiale, count(*) as qta, sum(Valore_Nominale) as Importo, 'LIQUIDAZIONI AD EREDI' as Tipo, Anno_Liquidazione, '1' as id
                FROM tab_xls_decessi_eredi
                WHERE Liquidazione_a_eredi = 'S'
                and Note_AO08 not in ('S2','SM')
                GROUP BY filiale, Anno_Liquidazione
                UNION
               
                SELECT filiale, count(*) as qta, sum(Valore_Nominale) as Importo, 'IN ATTESA DECISIONE EREDI' as Tipo, Anno_Liquidazione, '2' as id
                FROM tab_xls_decessi_eredi
                WHERE Intestazione_a_eredi <> 'S' 
                AND Liquidazione_a_eredi <> 'S'
                and Note_AO08 not in ('S2','SM','')
                GROUP BY filiale, Anno_Liquidazione
                UNION
                
                SELECT filiale, count(*) as qta, sum(Valore_Nominale) as Importo, 'SOFFERENZE' as Tipo, Anno_Liquidazione, '4' as id
                FROM tab_xls_recessi_esclusioni_sofferenze
                WHERE Escluso_x_Passaggio_a_Sofferenze = 'S' 
                and Note_AO08 not in ('S4','SA','SB','SC','')
                GROUP BY filiale, Anno_Liquidazione
                UNION
                
                SELECT filiale, count(*) as qta, sum(Valore_Nominale) as Importo, 'ESCLUSIONI' as Tipo, Anno_Liquidazione, '3' as id
                FROM tab_xls_recessi_esclusioni_sofferenze
                WHERE Escluso_x_Passaggio_a_Sofferenze <> 'S'
                and Note_AO08 not in ('S4','SA','SB','SC','')
                GROUP BY filiale, Anno_Liquidazione
                UNION
                
                SELECT filiale, count(*) as qta, sum(Valore_Nominale) as Importo, 'CESSIONI A BANCA' as Tipo, '' as Anno_Liquidazione, '5' as id
                FROM tab_xls_cessioni
                WHERE Cessione_a_Banca ='S' 
                and Note_AO08 not in ('S5','S4','SA','SB','SC','SM','VB') 
                GROUP BY filiale, Anno_Liquidazione 

                ") or die(mysql_error());;


