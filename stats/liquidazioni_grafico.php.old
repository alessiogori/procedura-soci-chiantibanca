// CREO LA VISTA DI APPOGGIO
$truncateviewF = mysqli_query($dbhandle,"DROP VIEW view_liquidazioni_fatte") or die(mysql_error());;
$viewF = mysqli_query($dbhandle," CREATE VIEW view_liquidazioni_fatte as 
                SELECT filiale, count(*) as qta, sum(Valore_Nominale) as Importo, 'LIQUIDAZIONI AD EREDI' as Tipo, right(Data,4) as Anno_Liquidazione, '1' as id
                FROM tab_xls_decessi_eredi
                WHERE Liquidazione_a_eredi in ('S','')
                and Note_AO08 in ('SM')
                GROUP BY filiale, right(Data,4)
                UNION
                
                SELECT filiale, count(*) as qta, sum(Valore_Nominale) as Importo, 'SOFFERENZE' as Tipo, right(Data_AO08,4) as Anno_Liquidazione, '4' as id
                FROM tab_xls_recessi_esclusioni_sofferenze
                WHERE Escluso_x_Passaggio_a_Sofferenze = 'S' 
                and Note_AO08 in ('SC')
                GROUP BY filiale, right(Data_AO08,4)
                UNION
                
                SELECT filiale, count(*) as qta, sum(Valore_Nominale) as Importo, 'ESCLUSIONI' as Tipo, right(Data_AO08,4) as Anno_Liquidazione, '3' as id
                FROM tab_xls_recessi_esclusioni_sofferenze
                WHERE Escluso_x_Passaggio_a_Sofferenze <> 'S'
                and Note_AO08 in ('S4','SA','SB','SC')
                GROUP BY filiale, right(Data_AO08,4)
                UNION
                
                SELECT filiale, count(*) as qta, sum(Valore_Nominale) as Importo, 'CESSIONI A BANCA' as Tipo, right(Data,4) as Anno_Liquidazione, '5' as id
                FROM tab_xls_cessioni
                WHERE Cessione_a_Banca ='S' 
                and Note_AO08 in ('S5','S4','SA','SB','SC','SM','VB') 
                GROUP BY filiale, right(Data,4) 

                ") or die(mysql_error());;


// Interrogo la view
$dettaglioF = " 
                SELECT  Tipo,
                        sum(qta)     as qta, 
                        sum(Importo) as Importo,
                        Anno_Liquidazione
                FROM view_liquidazioni_fatte
                WHERE filiale <> 999 
                AND Anno_Liquidazione >= 2020
                ".$condizionefiliale."
                GROUP BY Tipo, Anno_Liquidazione
                ORDER BY Anno_Liquidazione, id
                 ";

$result_areeF = $dbhandle->query($dettaglioF) or exit("Error code ({$dbhandle->errno}): {$dbhandle->error}");

$tab_dettaglioF .= '<table border="1" valign="top" width="100%">
