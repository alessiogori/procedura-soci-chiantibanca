    $updatefondo = "UPDATE tab_valorefondo SET aggiornamento=now(),capitale=".$capitale.",valore = ".$fondo.",plafond = ".$plafond;
    $queryupdate = mysqli_query($connection, $updatefondo);


echo '<center> Valore aggiornato! </center>';
