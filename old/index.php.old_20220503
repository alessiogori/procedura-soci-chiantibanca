    // --------------------
    // DATA ULTIMO CDA
    // --------------------     
    $select_cda = " SELECT CDA as CDA FROM tab_xls_ammissioni 
                    WHERE STR_TO_DATE(CDA, '%d/%m/%Y') = ( select max(STR_TO_DATE(CDA, '%d/%m/%Y')) 
                    FROM tab_xls_ammissioni ) 
                    GROUP BY CDA
                      " ;

    $qry_cda = mysqli_query($connection , $select_cda);
     while($cda = mysqli_fetch_array($qry_cda)){ 
         
         if ($cda['CDA'] == 'NEXT') {
              $cda_testo = $cda['CDA']." + NEXT";
              $cda_condizione = ""; 
         } else {
              $cda_testo = $cda['CDA']." + NEXT";
              $cda_condizione = " (CDA = '".$cda['CDA']."' OR CDA = 'NEXT')"; 
         }
    
      }    
    
    // --------------------
    // Conteggio Sconfini
    // --------------------     
    $select_sconf = " SELECT count(*) as qta FROM tab_xls_ammissioni
                      WHERE Manca_DB = 'S'
                      ORDER BY Filiale, Nominativo  " ;
    $qry_sconf = mysqli_query($connection, $select_sconf);

    $numerorigheSC = mysqli_num_rows($qry_sconf);
