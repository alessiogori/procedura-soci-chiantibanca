      <?php
        $select = " select DATE_FORMAT(aggiornamento, '%d/%m/%Y') as aggiornamento, aggiornamento as datacontrol, valore, plafond, capitale from tab_valorefondo";  
        $querydati = mysqli_query($connection, $select);      
        while($datifondo=mysqli_fetch_array($querydati)){       

	        // Date per colorefondo status aggiornamento
	        $f0 = date("Ymd") ;
	        $f1 = ( date("Ymd") - 7 );
	        $f2 = ( date("Ymd") - 15 );
	        $limiteF = date("Ymd",strtotime($datifondo['datacontrol'])); 

	        if ( ($limiteF <= $f0) AND ($limiteF > $f1) ) {$colorefondo = "gray";}
	        if ( ($limiteF <= $f1) AND ($limiteF > $f2) ) {$colorefondo = "yellow";}
	        if   ($limiteF <= $f2) {$colorefondo = "red";}

	        $data_aggto   = $datifondo['aggiornamento'];
	        $fondo_valore = $datifondo['valore'];
	        $plafond_valore = $datifondo['plafond'];
	        $capitale_valore = $datifondo['capitale'];
        }    

      echo 'Capitale Sociale &euro; '.number_format($capitale_valore,0,",",".").' - Fondo Riacquisto Azioni Proprie &euro; '.number_format($fondo_valore,0,",","."). ' - Plafond Soci &euro; '.number_format($plafond_valore,0,",",".").'
       <i>(dati aggiornati al <a href="check_vari.php?scelta=coge&action=" style="text-decoration:none;color:'.$colorefondo.';">'.$data_aggto.'</a>)</i>';
      ?>
    </span>
  
