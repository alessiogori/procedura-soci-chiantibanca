                    AND ".$cda_condizione ;
    $qry_esc1 = mysqli_query($connection, $select_esc1);
      while($esc1 = mysqli_fetch_array($qry_esc1)){ 
        {$esc1_qta = $esc1['qta']; }
      }                    

    // ------------------------------
    // Conteggio Cessioni a Banca 
    // ------------------------------ 
                    //AND Note_AO08 not in ('VC/S4','VB','VC','S5','S4','SB','SC','SM')  
    $select_ces1 = " SELECT count(*) as qta FROM tab_xls_cessioni
                    WHERE Cessione_a_Banca = 'S'
                    AND ".$cda_condizione ;
    $qry_ces1 = mysqli_query($connection, $select_ces1);
      while($ces1 = mysqli_fetch_array($qry_ces1)){ 
        {$ces1_qta = $ces1['qta']; }
      }                    

    // ------------------------------
